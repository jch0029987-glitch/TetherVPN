
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <RadioGroup
        android:id="@+id/modeSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radioTor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tor Mode"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/radioDirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Direct Mode"/>

        <RadioButton
            android:id="@+id/radioProxy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Proxy Mode"/>
    </RadioGroup>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start VPN"/>

    <Button
        android:id="@+id/stopButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stop VPN"/>

    <TextView
        android:id="@+id/logs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logs..."
        android:paddingTop="16dp"/>
</LinearLayout>
